{
  "ConnectionStrings": {
    "DefaultConnection": "db-connection"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "PasswordHash": {
    "SaltSize": 16,
    "HashSize": 32,
    "Iterations": 600000,
    "AlgorithmName": "SHA512"
  }
}
